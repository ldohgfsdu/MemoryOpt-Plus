{
    "arch": "arm",
    "data-layout": "e-m:e-p:32:32-Fi8-i64:64-v128:64:128-a:0:32-n32-S64",
    "env": "musl",
    "llvm-target": "armv7-unknown-linux-musleabi",
    "max-atomic-width": 64,
    "os": "linux",
    "target-family": ["unix"],
    "target-pointer-width": 32,
    "vendor": "unknown",
    "crt-objects-fallback": "false",
    "link-self-contained": {
        "components": {
            "unwind": true
        }
    }
}
